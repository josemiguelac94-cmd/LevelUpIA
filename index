  const david=precio*0.30,resto=precio-david;
  return{david,resto,emp:resto*0.25,pedro:resto*0.13,josemi:resto*0.13,markel:resto*0.115,adri:resto*0.115,closer:resto*0.10,setter:resto*0.10,pool:resto*0.06};
}

