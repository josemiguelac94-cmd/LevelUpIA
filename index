<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>LevelUp IA — CRM</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
:root{
  --bg:#0f0f0f;--bg2:#161616;--bg3:#1e1e1e;--bg4:#252525;
  --border:#2a2a2a;--border2:#333;
  --text:#f0f0f0;--text2:#a0a0a0;--text3:#666;
  --purple:#a78bfa;--purple-bg:#1a1730;--purple-dim:#7c3aed22;
  --teal:#34d399;--teal-bg:#0d2420;
  --amber:#fbbf24;--amber-bg:#1f1a0a;
  --red:#f87171;--red-bg:#1f0f0f;
  --blue:#60a5fa;--blue-bg:#0d1a2e;
  --green:#86efac;--green-bg:#0a1f12;
  --radius:10px;--radius-lg:14px;
}
*{box-sizing:border-box;margin:0;padding:0}
body{font-family:'DM Sans',sans-serif;background:var(--bg);color:var(--text);font-size:14px;min-height:100vh}
.layout{display:flex;min-height:100vh}

/* SIDEBAR */
.sidebar{width:220px;background:var(--bg2);border-right:1px solid var(--border);display:flex;flex-direction:column;flex-shrink:0}
.logo{padding:1.5rem 1.25rem 1rem;border-bottom:1px solid var(--border)}
.logo-name{font-size:15px;font-weight:600;letter-spacing:-.02em}
.logo-tag{font-size:11px;color:var(--text3);font-family:'DM Mono',monospace;margin-top:2px}
.nav{padding:.75rem 0;flex:1}
.nav-item{display:flex;align-items:center;gap:10px;padding:9px 1.25rem;cursor:pointer;color:var(--text2);font-size:13px;transition:all .15s;border-left:2px solid transparent}
.nav-item:hover{background:var(--bg3);color:var(--text)}
.nav-item.active{background:var(--purple-dim);color:var(--purple);border-left-color:var(--purple);font-weight:500}
.nav-icon{width:16px;height:16px;opacity:.7}
.nav-section{font-size:10px;color:var(--text3);text-transform:uppercase;letter-spacing:.08em;padding:1rem 1.25rem .4rem;font-weight:500}
.sidebar-bottom{padding:1rem 1.25rem;border-top:1px solid var(--border)}
.version{font-size:11px;color:var(--text3);font-family:'DM Mono',monospace}

/* MAIN */
.main{flex:1;display:flex;flex-direction:column;overflow:hidden}
.topbar{height:56px;background:var(--bg2);border-bottom:1px solid var(--border);display:flex;align-items:center;padding:0 1.5rem;gap:12px;flex-shrink:0}
.topbar-title{font-size:15px;font-weight:500;flex:1}
.topbar-badge{background:var(--purple-dim);color:var(--purple);font-size:11px;padding:3px 10px;border-radius:99px;font-weight:500}
.content{flex:1;overflow-y:auto;padding:1.5rem}

/* SECTIONS */
.section{display:none}.section.active{display:block}

/* METRICS */
.metrics{display:grid;grid-template-columns:repeat(4,1fr);gap:10px;margin-bottom:1.5rem}
.metric{background:var(--bg3);border:1px solid var(--border);border-radius:var(--radius);padding:1rem}
.metric-label{font-size:11px;color:var(--text3);text-transform:uppercase;letter-spacing:.06em;margin-bottom:6px}
.metric-val{font-size:22px;font-weight:600;letter-spacing:-.02em}
.metric-sub{font-size:11px;color:var(--text2);margin-top:3px}
.metric-val.green{color:var(--teal)}.metric-val.red{color:var(--red)}.metric-val.purple{color:var(--purple)}.metric-val.amber{color:var(--amber)}

/* CARDS */
.card{background:var(--bg3);border:1px solid var(--border);border-radius:var(--radius-lg);padding:1.25rem;margin-bottom:12px}
.card-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:1rem}
.card-title{font-weight:500;font-size:14px}
.card:hover{border-color:var(--border2)}

/* BADGES */
.badge{display:inline-block;padding:2px 10px;border-radius:99px;font-size:11px;font-weight:500;font-family:'DM Mono',monospace}
.badge-active{background:var(--teal-bg);color:var(--teal)}
.badge-pipeline{background:var(--amber-bg);color:var(--amber)}
.badge-pausado{background:var(--bg4);color:var(--text3)}
.badge-ia{background:var(--purple-bg);color:var(--purple)}
.badge-ads{background:var(--amber-bg);color:var(--amber)}
.badge-alta{background:var(--red-bg);color:var(--red)}
.badge-media{background:var(--amber-bg);color:var(--amber)}
.badge-baja{background:var(--bg4);color:var(--text3)}

/* AVATAR */
.avatar{width:36px;height:36px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-weight:600;font-size:12px;flex-shrink:0;font-family:'DM Mono',monospace}
.av-p{background:var(--purple-bg);color:var(--purple)}
.av-j{background:var(--teal-bg);color:var(--teal)}
.av-m{background:var(--amber-bg);color:var(--amber)}
.av-a{background:var(--red-bg);color:var(--red)}
.av-d{background:var(--blue-bg);color:var(--blue)}
.av-e{background:var(--green-bg);color:var(--green)}

/* TABLE */
.table-wrap{overflow-x:auto}
table{width:100%;border-collapse:collapse;font-size:13px}
th{text-align:left;color:var(--text3);font-size:11px;text-transform:uppercase;letter-spacing:.06em;padding:8px 12px;border-bottom:1px solid var(--border);font-weight:500}
td{padding:10px 12px;border-bottom:1px solid var(--border);color:var(--text);vertical-align:middle}
tr:last-child td{border-bottom:none}
tr:hover td{background:var(--bg4)}

/* GRID */
.grid2{display:grid;grid-template-columns:1fr 1fr;gap:12px}
.grid3{display:grid;grid-template-columns:repeat(3,1fr);gap:10px}
.grid4{display:grid;grid-template-columns:repeat(4,1fr);gap:10px}

/* SECTION HEADER */
.sec-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:1.25rem}
.sec-title{font-size:16px;font-weight:500}
.sec-sub{font-size:12px;color:var(--text3);margin-top:2px}

/* SLABEL */
.slabel{font-size:11px;color:var(--text3);text-transform:uppercase;letter-spacing:.08em;font-weight:500;margin-bottom:8px}

/* BTN */
button{background:transparent;border:1px solid var(--border2);color:var(--text);padding:7px 14px;border-radius:var(--radius);cursor:pointer;font-size:13px;font-family:'DM Sans',sans-serif;transition:all .15s}
button:hover{background:var(--bg4);border-color:var(--text3)}
button.primary{background:var(--purple-dim);border-color:var(--purple);color:var(--purple)}
button.primary:hover{background:#2a1f5e}

/* FORM */
.form-group{margin-bottom:12px}
.form-group label{display:block;font-size:12px;color:var(--text2);margin-bottom:5px}
input[type=text],input[type=number],input[type=date],select,textarea{background:var(--bg4);border:1px solid var(--border2);color:var(--text);padding:7px 10px;border-radius:var(--radius);font-size:13px;font-family:'DM Sans',sans-serif;width:100%;outline:none}
input:focus,select:focus,textarea:focus{border-color:var(--purple)}
select option{background:var(--bg4)}

/* PIPELINE */
.kanban{display:grid;grid-template-columns:repeat(4,1fr);gap:10px}
.kanban-col{background:var(--bg3);border:1px solid var(--border);border-radius:var(--radius-lg);padding:.75rem}
.kanban-col-header{font-size:12px;font-weight:500;margin-bottom:10px;display:flex;align-items:center;justify-content:space-between}
.kanban-count{background:var(--bg4);color:var(--text3);font-size:11px;padding:1px 7px;border-radius:99px}
.kanban-card{background:var(--bg2);border:1px solid var(--border);border-radius:var(--radius);padding:.75rem;margin-bottom:8px;cursor:pointer}
.kanban-card:hover{border-color:var(--border2)}
.kanban-card-name{font-weight:500;font-size:13px;margin-bottom:3px}
.kanban-card-sub{font-size:11px;color:var(--text2)}
.kanban-card-footer{display:flex;justify-content:space-between;margin-top:8px;font-size:11px;color:var(--text3)}

/* CHAT */
.chat-container{background:var(--bg3);border:1px solid var(--border);border-radius:var(--radius-lg);overflow:hidden}
.chat-msgs{padding:1.25rem;min-height:180px;max-height:360px;overflow-y:auto;display:flex;flex-direction:column;gap:12px}
.msg{max-width:82%;padding:10px 14px;border-radius:12px;font-size:13px;line-height:1.6;white-space:pre-wrap}
.msg-user{background:var(--purple-dim);border:1px solid var(--purple);color:var(--text);align-self:flex-end;border-bottom-right-radius:3px}
.msg-ai{background:var(--bg4);border:1px solid var(--border2);color:var(--text);align-self:flex-start;border-bottom-left-radius:3px}
.msg-ai .msg-tag{font-size:10px;color:var(--purple);font-family:'DM Mono',monospace;margin-bottom:4px;font-weight:500}
.chat-input-area{display:flex;gap:8px;padding:1rem;border-top:1px solid var(--border);background:var(--bg2)}
.chat-input-area input{flex:1;font-size:13px}
.chat-input-area button{padding:7px 16px;white-space:nowrap}

/* PROGRESS */
.progress{background:var(--bg4);border-radius:99px;height:4px;margin-top:8px;overflow:hidden}
.progress-fill{height:4px;border-radius:99px;background:linear-gradient(90deg,var(--purple),var(--teal));transition:width .4s}

/* ROW */
.row{display:flex;align-items:center;gap:10px;padding:10px 0;border-bottom:1px solid var(--border)}
.row:last-child{border-bottom:none}
.row-name{font-weight:500;font-size:13px}
.row-sub{font-size:12px;color:var(--text2)}
.row-right{margin-left:auto;text-align:right}

/* CHECKBOX */
input[type=checkbox]{width:16px;height:16px;cursor:pointer;accent-color:var(--purple)}

/* TEAM CARD */
.team-card{background:var(--bg3);border:1px solid var(--border);border-radius:var(--radius-lg);padding:1rem;display:flex;gap:12px}
.team-card:hover{border-color:var(--border2)}
.team-name{font-weight:500;font-size:13px;margin-bottom:2px}
.team-role{font-size:12px;color:var(--text2);margin-bottom:8px}
.team-stat{font-size:11px;color:var(--text3);margin-bottom:2px}
.team-stat span{color:var(--text);font-weight:500}

/* MODAL */
.modal-overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,.7);z-index:100;align-items:center;justify-content:center}
.modal-overlay.open{display:flex}
.modal{background:var(--bg2);border:1px solid var(--border2);border-radius:var(--radius-lg);padding:1.5rem;width:420px;max-height:80vh;overflow-y:auto}
.modal-title{font-size:15px;font-weight:500;margin-bottom:1.25rem}
.modal-footer{display:flex;gap:8px;justify-content:flex-end;margin-top:1.25rem}

/* SCROLLBAR */
::-webkit-scrollbar{width:4px;height:4px}
::-webkit-scrollbar-track{background:var(--bg2)}
::-webkit-scrollbar-thumb{background:var(--border2);border-radius:99px}

/* CALC RESULT */
.calc-grid{display:grid;grid-template-columns:repeat(5,1fr);gap:6px;margin-top:12px}
.calc-item{background:var(--bg4);border:1px solid var(--border);border-radius:var(--radius);padding:.6rem .75rem}
.calc-item .lbl{font-size:10px;color:var(--text3);text-transform:uppercase;letter-spacing:.05em;margin-bottom:4px}
.calc-item .val{font-size:15px;font-weight:600;font-family:'DM Mono',monospace}
.calc-item.empresa .val{color:var(--teal)}
.calc-item.tecnico .val{color:var(--blue)}

.dot{width:8px;height:8px;border-radius:50%;flex-shrink:0}
.dot-alta{background:var(--red)}
.dot-media{background:var(--amber)}
.dot-baja{background:var(--text3)}

.sep{height:1px;background:var(--border);margin:1rem 0}
</style>
</head>
<body>

<div class="layout">
  <aside class="sidebar">
    <div class="logo">
      <div class="logo-name">LevelUp IA</div>
      <div class="logo-tag">CRM v1.0</div>
    </div>
    <nav class="nav">
      <div class="nav-section">Principal</div>
      <div class="nav-item active" onclick="showTab('dashboard',this)"><span>◈</span> Dashboard</div>
      <div class="nav-item" onclick="showTab('clientes',this)"><span>◉</span> Clientes</div>
      <div class="nav-item" onclick="showTab('pipeline',this)"><span>◧</span> Pipeline</div>
      <div class="nav-section">Gestión</div>
      <div class="nav-item" onclick="showTab('equipo',this)"><span>◎</span> Equipo</div>
      <div class="nav-item" onclick="showTab('comisiones',this)"><span>◈</span> Comisiones</div>
      <div class="nav-item" onclick="showTab('tareas',this)"><span>◻</span> Tareas</div>
      <div class="nav-section">Finanzas</div>
      <div class="nav-item" onclick="showTab('financiero',this)"><span>◆</span> Financiero</div>
      <div class="nav-section">IA</div>
      <div class="nav-item" onclick="showTab('asistente',this)"><span>◈</span> Asistente</div>
    </nav>
    <div class="sidebar-bottom">
      <div class="version">levelupia.crm · 2025</div>
    </div>
  </aside>

  <div class="main">
    <div class="topbar">
      <div class="topbar-title" id="topbar-title">Dashboard</div>
      <span class="topbar-badge" id="topbar-badge">Vista general</span>
      <button class="primary" onclick="showTab('asistente',null)">+ Asistente IA</button>
    </div>
    <div class="content">

      <!-- DASHBOARD -->
      <div id="sec-dashboard" class="section active">
        <div class="metrics" id="dash-metrics"></div>
        <div class="grid2">
          <div>
            <div class="slabel">Clientes activos</div>
            <div class="card" id="dash-clientes"></div>
          </div>
          <div>
            <div class="slabel">Tareas urgentes</div>
            <div class="card" id="dash-tareas"></div>
            <div class="slabel" style="margin-top:1rem">Facturacion recurrente</div>
            <div class="card" id="dash-fact"></div>
          </div>
        </div>
      </div>

      <!-- CLIENTES -->
      <div id="sec-clientes" class="section">
        <div class="sec-header">
          <div><div class="sec-title">Clientes</div><div class="sec-sub" id="cli-count"></div></div>
          <button class="primary" onclick="openModal('cliente')">+ Nuevo cliente</button>
        </div>
        <div id="lista-clientes"></div>
      </div>

      <!-- PIPELINE -->
      <div id="sec-pipeline" class="section">
        <div class="sec-header">
          <div><div class="sec-title">Pipeline</div><div class="sec-sub">Prospectos en proceso</div></div>
          <button class="primary" onclick="openModal('pipeline')">+ Nuevo prospecto</button>
        </div>
        <div class="kanban" id="kanban"></div>
      </div>

      <!-- EQUIPO -->
      <div id="sec-equipo" class="section">
        <div class="slabel">Socios fundadores</div>
        <div class="grid2" id="eq-socios" style="margin-bottom:1.5rem"></div>
        <div class="slabel">Equipo comercial</div>
        <div class="grid3" id="eq-setters" style="margin-bottom:1.5rem"></div>
        <div class="slabel">Colaboradores externos</div>
        <div class="grid2" id="eq-colab"></div>
      </div>

      <!-- COMISIONES -->
      <div id="sec-comisiones" class="section">
        <div class="slabel">Estructura vigente</div>
        <div class="card" style="margin-bottom:1rem">
          <div class="table-wrap">
            <table>
              <thead><tr><th>Quien</th><th>%</th><th>Base</th><th>Aplica</th></tr></thead>
              <tbody>
                <tr><td>Empresa</td><td style="color:var(--teal);font-family:'DM Mono',monospace">25%</td><td>Resto tras David/Edu</td><td>Siempre</td></tr>
                <tr><td>Pedro</td><td style="color:var(--purple);font-family:'DM Mono',monospace">13%</td><td>Resto</td><td>Toda la facturacion</td></tr>
                <tr><td>Josemi</td><td style="color:var(--purple);font-family:'DM Mono',monospace">13%</td><td>Resto</td><td>Toda la facturacion</td></tr>
                <tr><td>Markel</td><td style="color:var(--purple);font-family:'DM Mono',monospace">11.5%</td><td>Resto</td><td>Toda la facturacion</td></tr>
                <tr><td>Adri</td><td style="color:var(--purple);font-family:'DM Mono',monospace">11.5%</td><td>Resto</td><td>Toda la facturacion</td></tr>
                <tr><td>Closer</td><td style="font-family:'DM Mono',monospace">10%</td><td>Resto</td><td>Setup + retencion sus clientes</td></tr>
                <tr><td>Setter</td><td style="font-family:'DM Mono',monospace">10%</td><td>Resto</td><td>Setup + retencion sus clientes</td></tr>
                <tr><td>Pool / 6</td><td style="font-family:'DM Mono',monospace">6%</td><td>Resto</td><td>Toda la facturacion</td></tr>
                <tr><td>David</td><td style="color:var(--blue);font-family:'DM Mono',monospace">30%</td><td>Bruto IA</td><td>Antes del reparto</td></tr>
                <tr><td>Edu</td><td style="color:var(--green);font-family:'DM Mono',monospace">600/700€</td><td>Fijo por cliente</td><td>Mayo-Jun / Jul+</td></tr>
              </tbody>
            </table>
          </div>
        </div>
        <div class="slabel">Calculadora</div>
        <div class="card">
          <div style="display:flex;gap:10px;flex-wrap:wrap">
            <div class="form-group" style="margin:0"><label>Tipo</label><select id="calc-tipo" onchange="calcComision()" style="width:160px"><option value="ia-setup">IA Setup</option><option value="ia-ret">IA Retencion</option><option value="ads">Ads</option></select></div>
            <div class="form-group" style="margin:0"><label>Escala</label><select id="calc-escala" onchange="calcComision()" style="width:120px"><option>1</option><option>2</option><option>3</option><option>4</option></select></div>
            <div class="form-group" style="margin:0"><label>Periodo</label><select id="calc-mes" onchange="calcComision()" style="width:140px"><option value="mayo">Mayo-Junio</option><option value="julio">Julio+</option></select></div>
          </div>
          <div id="calc-result"></div>
        </div>
        <div class="sep"></div>
        <div class="slabel">Escalado setter</div>
        <div class="card">
          <table><thead><tr><th>Ventas/mes</th><th>% Setter</th></tr></thead>
          <tbody>
            <tr><td>1 a 6</td><td style="color:var(--text);font-family:'DM Mono',monospace">10%</td></tr>
            <tr><td>7 a 14</td><td style="color:var(--amber);font-family:'DM Mono',monospace">11%</td></tr>
            <tr><td>15+</td><td style="color:var(--teal);font-family:'DM Mono',monospace">12%</td></tr>
          </tbody></table>
        </div>
      </div>

      <!-- TAREAS -->
      <div id="sec-tareas" class="section">
        <div class="sec-header">
          <div><div class="sec-title">Tareas</div><div class="sec-sub" id="task-count"></div></div>
          <button class="primary" onclick="openModal('tarea')">+ Nueva tarea</button>
        </div>
        <div id="lista-tareas"></div>
      </div>

      <!-- FINANCIERO -->
      <div id="sec-financiero" class="section">
        <div class="metrics" id="fin-metrics"></div>
        <div class="grid2">
          <div>
            <div class="slabel">Costes fijos mensuales</div>
            <div class="card">
              <table><thead><tr><th>Concepto</th><th>Antes SL</th><th>Desde julio</th></tr></thead>
              <tbody>
                <tr><td>SS autonomos x4</td><td style="color:var(--text3)">—</td><td>1.280€</td></tr>
                <tr><td>n8n + OpenAI</td><td>20€</td><td>20€</td></tr>
                <tr><td>ManyChat + CRM</td><td>35€</td><td>35€</td></tr>
                <tr><td>Workspace + Scraping</td><td>68€</td><td>68€</td></tr>
                <tr><td>Gestoria</td><td style="color:var(--text3)">—</td><td>125€</td></tr>
                <tr><td>Anuncios + web</td><td>310€</td><td>310€</td></tr>
                <tr><td>Imprevistos</td><td>50€</td><td>50€</td></tr>
                <tr><td style="font-weight:600">Total</td><td style="font-weight:600;color:var(--amber)">483€</td><td style="font-weight:600;color:var(--red)">1.888€</td></tr>
              </tbody></table>
            </div>
          </div>
          <div>
            <div class="slabel">Proyeccion 6 meses</div>
            <div class="card">
              <div id="proy-table"></div>
            </div>
            <div class="slabel" style="margin-top:1rem">Inversion socios</div>
            <div class="card">
              <table><thead><tr><th>Fecha</th><th>c/socio</th><th>Total</th></tr></thead>
              <tbody>
                <tr><td>20 abril</td><td>200€</td><td>800€</td></tr>
                <tr><td>20 mayo</td><td>200€</td><td>800€</td></tr>
                <tr><td>Junio SL</td><td>1.500€</td><td>6.000€</td></tr>
                <tr><td style="font-weight:600">Total</td><td style="font-weight:600">1.900€</td><td style="font-weight:600;color:var(--purple)">7.600€</td></tr>
              </tbody></table>
            </div>
          </div>
        </div>
      </div>

      <!-- ASISTENTE -->
      <div id="sec-asistente" class="section">
        <div class="sec-header"><div class="sec-title">Asistente IA</div></div>
        <div class="card" style="margin-bottom:12px;background:var(--purple-bg);border-color:var(--purple)">
          <div style="font-size:12px;color:var(--text2);line-height:1.7">
            Ejemplos: <code style="color:var(--purple)">"Añade cliente Diego, fisio, IA escala 1, cerrado por Pedro"</code> — <code style="color:var(--purple)">"Nueva tarea: llamar a Iker, responsable Josemi, urgente"</code> — <code style="color:var(--purple)">"Marca tarea de scraping como completada"</code> — <code style="color:var(--purple)">"Cuantos clientes tenemos"</code>
          </div>
        </div>
        <div class="chat-container">
          <div class="chat-msgs" id="chat-msgs">
            <div class="msg msg-ai"><div class="msg-tag">LEVELUP IA ASSISTANT</div>Hola Josemi. Soy el asistente del CRM. Puedo modificar clientes, tareas, pipeline y equipo con texto natural. Que necesitas?</div>
