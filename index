function calcComision(){
  const tipo=document.getElementById('calc-tipo')?.value;
  const escala=parseInt(document.getElementById('calc-escala')?.value||1)-1;
  const mes=document.getElementById('calc-mes')?.value;
  if(!tipo)return;
  let precio,david=0,edu=0;
  if(tipo==='ia-setup'){precio=SETUPS[escala];david=precio*0.30;}
  else if(tipo==='ia-ret'){precio=RETS[escala];david=precio*0.30;}
  else{precio=mes==='julio'?1400:1200;edu=mes==='julio'?700:600;}
  const resto=precio-(david||edu);
  const r={emp:resto*0.25,pedro:resto*0.13,josemi:resto*0.13,markel:resto*0.115,adri:resto*0.115,closer:resto*0.10,setter:resto*0.10,pool:resto*0.06/6};
  document.getElementById('calc-result').innerHTML=`
    <div style="margin-top:12px;font-size:11px;color:var(--text3);margin-bottom:8px">Precio: ${fmt(precio)} · Resto a repartir: ${fmt(resto)}</div>
    <div class="calc-grid">
      ${david?`<div class="calc-item tecnico"><div class="lbl">David</div><div class="val">${fmt(david)}</div></div>`:''}
      ${edu?`<div class="calc-item tecnico"><div class="lbl">Edu</div><div class="val">${fmt(edu)}</div></div>`:''}
      <div class="calc-item empresa"><div class="lbl">Empresa</div><div class="val">${fmt(r.emp)}</div></div>
      <div class="calc-item"><div class="lbl">Pedro</div><div class="val">${fmt(r.pedro)}</div></div>
      <div class="calc-item"><div class="lbl">Josemi</div><div class="val">${fmt(r.josemi)}</div></div>
      <div class="calc-item"><div class="lbl">Markel</div><div class="val">${fmt(r.markel)}</div></div>
      <div class="calc-item"><div class="lbl">Adri</div><div class="val">${fmt(r.adri)}</div></div>
      <div class="calc-item"><div class="lbl">Setter</div><div class="val">${fmt(r.setter)}</div></div>
      <div class="calc-item"><div class="lbl">Closer</div><div class="val">${fmt(r.closer)}</div></div>
      <div class="calc-item"><div class="lbl">Pool c/u</div><div class="val">${fmt(r.pool)}</div></div>
    </div>`;
}

function toggleTarea(id){
  const t=state.tareas.find(t=>t.id===id);
  if(t)t.estado=t.estado==='completada'?'pendiente':'completada';
  renderTareas();
  if(document.getElementById('sec-dashboard').classList.contains('active'))renderDashboard();
}

function openModal(type){
  if(type==='cliente')document.getElementById('f-fecha').value=today;
  if(type==='tarea')document.getElementById('t-fecha').value=today;
  document.getElementById('modal-'+type).classList.add('open');
}
function closeModal(type){document.getElementById('modal-'+type).classList.remove('open');}

function guardarCliente(){
  const nombre=document.getElementById('f-nombre').value.trim();
  if(!nombre)return;
  state.clientes.push({id:Date.now(),nombre,sector:document.getElementById('f-sector').value||'—',servicio:document.getElementById('f-servicio').value,escala:parseInt(document.getElementById('f-escala').value),estado:'activo',fechaInicio:document.getElementById('f-fecha').value||today,setter:document.getElementById('f-setter').value||'—',closer:document.getElementById('f-closer').value||'Adri',cerradoPor:document.getElementById('f-cerrado').value||'Pedro',notas:document.getElementById('f-notas').value});
  closeModal('cliente');renderClientes();renderDashboard();
}

function guardarTarea(){
  const titulo=document.getElementById('t-titulo').value.trim();
  if(!titulo)return;
  state.tareas.push({id:Date.now(),titulo,resp:document.getElementById('t-resp').value||'Josemi',prio:document.getElementById('t-prio').value,estado:'pendiente',fecha:document.getElementById('t-fecha').value||today});
  closeModal('tarea');renderTareas();renderDashboard();
}

function guardarPipeline(){
  const nombre=document.getElementById('p-nombre').value.trim();
  if(!nombre)return;
  state.pipeline.push({id:Date.now(),nombre,sector:document.getElementById('p-sector').value||'—',valor:parseInt(document.getElementById('p-valor').value)||1300,fase:document.getElementById('p-fase').value,resp:document.getElementById('p-resp').value||'Pedro',notas:document.getElementById('p-notas').value});
  closeModal('pipeline');renderPipeline();
}

function enviarChat(){
  const input=document.getElementById('chat-input');
  const msg=input.value.trim();if(!msg)return;
  input.value='';
  const msgs=document.getElementById('chat-msgs');
  msgs.innerHTML+=`<div class="msg msg-user">${msg}</div>`;
  msgs.scrollTop=msgs.scrollHeight;
  setTimeout(()=>{
    const resp=procesarComando(msg);
    msgs.innerHTML+=`<div class="msg msg-ai"><div class="msg-tag">LEVELUP IA ASSISTANT</div>${resp}</div>`;
    msgs.scrollTop=msgs.scrollHeight;
  },350);
}

function procesarComando(msg){
  const m=msg.toLowerCase();
  if(m.includes('añade cliente')||m.includes('nuevo cliente')){
    const nombre=msg.match(/cliente\s+([A-Za-zÀ-ú\s]+?)(?:,|\.|$)/i)?.[1]?.trim();
    if(!nombre)return'Dime el nombre. Ej: "Añade cliente Diego, fisio, IA escala 1, cerrado por Pedro"';
    const servicio=m.includes('ads')?'ads':'ia';
    const escala=parseInt(m.match(/escala\s*(\d)/i)?.[1]||'1');
    const sector=m.match(/,\s*([^,]+?),\s*(?:ia|ads)/i)?.[1]?.trim()||'—';
    const cerradoPor=m.match(/cerrado por\s+(\w+)/i)?.[1]||'Pedro';
    state.clientes.push({id:Date.now(),nombre,sector,servicio,escala,estado:'activo',fechaInicio:today,setter:'—',closer:'Adri',cerradoPor,notas:''});
    renderClientes();renderDashboard();
    return`Cliente "${nombre}" añadido. Servicio: ${servicio==='ia'?'IA escala '+escala:'Ads'}. Cerrado por ${cerradoPor}.`;
  }
  if(m.includes('nueva tarea')||m.includes('añade tarea')){
    const titulo=msg.match(/tarea[:\s]+(.+?)(?:,\s*responsable|,\s*resp|$)/i)?.[1]?.trim();
    if(!titulo)return'Dime el titulo. Ej: "Nueva tarea: llamar Iker, responsable Josemi, urgente"';
    const resp=msg.match(/(?:responsable|resp)[:\s]+(\w+)/i)?.[1]||'Josemi';
    const prio=m.includes('urgente')||m.includes('alta')?'alta':m.includes('baja')?'baja':'media';
    state.tareas.push({id:Date.now(),titulo,resp,prio,estado:'pendiente',fecha:today});
    renderTareas();renderDashboard();
    return`Tarea "${titulo}" creada. Responsable: ${resp}. Prioridad: ${prio}.`;
  }
  if(m.includes('completada')||m.includes('completar')||m.includes('hecha')){
    const kw=msg.replace(/marca|tarea|como|completada|completar|hecha/gi,'').trim().toLowerCase();
    const t=state.tareas.find(t=>kw&&t.titulo.toLowerCase().includes(kw)&&t.estado==='pendiente');
    if(t){t.estado='completada';renderTareas();renderDashboard();return`Tarea "${t.titulo}" marcada como completada.`;}
    return`No encontre esa tarea pendiente. Escribe parte del titulo.`;
  }
  if(m.includes('cambia estado')||m.includes('pausar')||m.includes('pausado')||m.includes('activa')){
    const est=m.includes('pausad')?'pausado':m.includes('activ')?'activo':'pipeline';
    const kw=msg.replace(/cambia|estado|de|a|pausado|activo|pausar|activar/gi,'').trim().toLowerCase();
    const c=state.clientes.find(c=>kw&&c.nombre.toLowerCase().includes(kw));
    if(c){c.estado=est;renderClientes();renderDashboard();return`Estado de "${c.nombre}" cambiado a "${est}".`;}
    return`No encontre ese cliente.`;
  }
  if(m.includes('añade prospecto')||m.includes('nuevo prospecto')){
    const nombre=msg.match(/prospecto[:\s]+([A-Za-zÀ-ú\s]+?)(?:,|$)/i)?.[1]?.trim();
    if(!nombre)return'Dime el nombre del prospecto.';
    const fase=m.includes('reunion')?'reunion':m.includes('cierre')?'cierre':m.includes('ganado')?'ganado':'contacto';
    state.pipeline.push({id:Date.now(),nombre,sector:'—',valor:1300,fase,resp:'Pedro',notas:''});
    renderPipeline();
    return`Prospecto "${nombre}" añadido al pipeline en fase "${fase}".`;
  }
  if(m.includes('resumen')||m.includes('cuantos')||m.includes('estado')){
    const a=state.clientes.filter(c=>c.estado==='activo');
    const ia=a.filter(c=>c.servicio==='ia');
    const ads=a.filter(c=>c.servicio==='ads');
    const pend=state.tareas.filter(t=>t.estado==='pendiente');
    const fact=ia.reduce((s,c)=>s+(RETS[c.escala-1]||0),0)+ads.length*1200;
    return`Resumen actual:\n— ${a.length} clientes activos (${ia.length} IA, ${ads.length} Ads)\n— ${fmt(fact)}/mes facturacion recurrente\n— ${pend.length} tareas pendientes (${pend.filter(t=>t.prio==='alta').length} urgentes)\n— ${state.pipeline.length} prospectos en pipeline`;
  }
  return`No entendi el comando. Puedes decirme:\n— "Añade cliente [nombre], [sector], IA escala [1-4], cerrado por [persona]"\n— "Nueva tarea: [titulo], responsable [persona], urgente/media/baja"\n— "Marca tarea [titulo] como completada"\n— "Cambia estado de [cliente] a pausado/activo"\n— "Añade prospecto [nombre], fase reunion/cierre"\n— "Resumen"`;
}

document.querySelectorAll('.modal-overlay').forEach(m=>m.addEventListener('click',e=>{if(e.target===m)m.classList.remove('open');}));
renderDashboard();
calcComision();
</script>
